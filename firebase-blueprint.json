{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's classroom profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "focusPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Note": {
      "title": "Study Note",
      "description": "A student's study notes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    },
    "QuestionPaper": {
      "title": "Question Paper",
      "description": "Previous year question papers or practice sets",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User study notes"
    },
    "/questionPapers/{paperId}": {
      "schema": "QuestionPaper",
      "description": "User question papers"
    }
  }
}
